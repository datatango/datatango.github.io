---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Developer, preservationist, and filmmaker based in Chicago.", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const pageTitle = title === "Matthew Yang" ? title : `${title} — Matthew Yang`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Matthew Yang" />
    {ogImage && <meta property="og:image" content={ogImage} />}

<title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="alternate" type="application/rss+xml" title="Matthew Yang — Writing" href="/rss.xml" />
    <!-- Font preloads -->
    <link rel="preload" as="font" href="/fonts/Geist-Light.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/Geist-Medium.woff2" type="font/woff2" crossorigin />
<!-- Google Analytics start-->
    {import.meta.env.PROD && import.meta.env.PUBLIC_GA_MEASUREMENT_ID && (
      <script is:inline define:vars={{ measurementId: import.meta.env.PUBLIC_GA_MEASUREMENT_ID }}>
        window.addEventListener('load', function() {
          var script = document.createElement('script');
          script.src = 'https://www.googletagmanager.com/gtag/js?id=' + measurementId;
          script.async = true;
          document.head.appendChild(script);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', measurementId);
        });
      </script>
    )}
    <!-- Google Analytics end-->
  </head>
  <body class="bg-[#1a0d1f] text-zinc-200 text-lg min-h-screen">
    <nav class="max-w-2xl mx-auto px-4 py-8">
      <ul class="flex gap-6 font-medium">
        <li><a href={import.meta.env.BASE_URL} class="hover:text-zinc-400 transition-colors">about</a></li>
        <li><a href={`${import.meta.env.BASE_URL}work`} class="hover:text-zinc-400 transition-colors">work</a></li>
        <li><a href={`${import.meta.env.BASE_URL}writing`} class="hover:text-zinc-400 transition-colors">writing</a></li>
      </ul>
    </nav>
    <main class="max-w-2xl mx-auto px-4 pb-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>