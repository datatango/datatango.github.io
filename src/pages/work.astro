---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Base title="Work">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      projects.map((project, i) => (
        <a
          href={`${import.meta.env.BASE_URL}work/${project.id}`}
          class="group block overflow-hidden"
        >
          <div class="aspect-video w-full overflow-hidden bg-zinc-900 mb-3">
            {project.data.hero ? (
              <img
                src={`/work/${project.data.hero}`}
                alt={project.data.title}
                loading={i === 0 ? "eager" : "lazy"}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            ) : (
              <div class="w-full h-full bg-zinc-800" />
            )}
          </div>
          <h2 class="text-lg font-medium group-hover:text-zinc-400 transition-colors">
            {project.data.title}
          </h2>
        </a>
      ))
    }
  </div>
</Base>
