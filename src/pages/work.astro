---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import type { ImageMetadata } from "astro";

const projects = (await getCollection("work")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/work/**/*.{jpg,jpeg,png,gif,webp}"
);

const projectsWithImages = await Promise.all(
  projects.map(async (project) => {
    const key = `../assets/work/${project.data.hero}`;
    const mod = imageModules[key];
    const image = mod ? (await mod()).default : null;
    return { ...project, image };
  })
);
---

<Base title="Work">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      projectsWithImages.map((project) => (
        <a
          href={`${import.meta.env.BASE_URL}work/${project.id}`}
          class="group block overflow-hidden"
        >
          <div class="aspect-video w-full overflow-hidden bg-zinc-900 mb-3">
            {project.image ? (
              <Image
                src={project.image}
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            ) : (
              <div class="w-full h-full bg-zinc-800" />
            )}
          </div>
          <h2 class="text-lg font-medium group-hover:text-zinc-400 transition-colors">
            {project.data.title}
          </h2>
        </a>
      ))
    }
  </div>
</Base>
